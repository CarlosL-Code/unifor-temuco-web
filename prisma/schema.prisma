generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  imageSrc    String
  colors      String   // JSON stringified array of hex codes
  description String?
  sizes       String?  // JSON stringified array of sizes (e.g. ["S", "M", "L"])
  material    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
